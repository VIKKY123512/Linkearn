// LinkEarn data model
// SQLite by default so the project runs with zero external services.
// Swap provider to "postgresql" + a DATABASE_URL for production (see README).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(USER)
  apiKey        String   @unique @default(cuid())
  balance       Float    @default(0)
  totalEarned   Float    @default(0)
  referralCode  String   @unique @default(cuid())
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")
  referralEarn  Float    @default(0)
  suspended     Boolean  @default(false)
  createdAt     DateTime @default(now())

  links       Link[]
  withdrawals Withdrawal[]
}

model Link {
  id          String    @id @default(cuid())
  code        String    @unique
  originalUrl String
  alias       String?
  passwordHash String?
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  clicks Click[]
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id])
  ipHash    String
  country   String?
  device    String?
  browser   String?
  earning   Float    @default(0)
  isFraud   Boolean  @default(false)
  fraudReason String?
  createdAt DateTime @default(now())
}

model Withdrawal {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  amount    Float
  method    String
  details   String
  status    WithdrawStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Singleton row (id always 1) holding platform-wide economics.
model Settings {
  id                Int    @id @default(1)
  cpmRate           Float  @default(5.0)  // $ earned per 1000 valid views, platform-wide
  userSharePercent  Float  @default(70)   // % of CPM paid to the link owner
  referralPercent   Float  @default(20)   // % of a referred user's earnings paid to referrer
  minWithdraw       Float  @default(5)
  siteName          String @default("LinkEarn")
}
